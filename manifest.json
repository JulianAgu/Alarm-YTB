{
  "manifest_version": 3,
  "name": "Alarm YTB",
  "version": "2.0",
  "description": "Set YouTube alarms to play automatically at specific intervals or every hour.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["alarms", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "Open Alarm YTB"
  },
  "background": {
    "service_worker": "background.js"
  }
}